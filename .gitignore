# Python cache — generated automatically when you run a script, never belongs in a repo
__pycache__/
*.pyc
*.pyo

# Virtual environments — if you ever run "python -m venv venv" to isolate dependencies
venv/
.venv/
env/

# Output files generated by the scripts (lyrics, transcripts, translations)
# These are personal results, not part of the source code
*.txt
!requirements.txt

# OS-generated junk files
.DS_Store
Thumbs.db
